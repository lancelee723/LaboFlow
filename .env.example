# ─────────────────────────────────────────────────────────────
# Labo-Flow — Shared environment variables
# Copy to .env and fill in real values. This file is consumed
# by dev.sh / setup-all.sh and propagated to each component.
# ─────────────────────────────────────────────────────────────

# ══ Unified entry ══
NGINX_PORT=3008
PUBLIC_BASE_URL=http://localhost:3008

# ══ Clawith (main platform) ══
CLAWITH_FRONTEND_PORT=3080
CLAWITH_BACKEND_PORT=8008
# JWT_SECRET_KEY is read by Clawith backend AND shared with LightRAG/AIPPT
# for SSO. Generate with: python -c 'import secrets; print(secrets.token_urlsafe(48))'
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256

# ══ LightRAG (knowledge base) ══
LIGHTRAG_PORT=9621
LIGHTRAG_HOST=0.0.0.0
# LightRAG uses TOKEN_SECRET internally; we set it equal to JWT_SECRET_KEY
# so Clawith-minted JWTs validate on LightRAG side (SSO).
# See: LightRAG/lightrag/api/auth.py
TOKEN_SECRET=${JWT_SECRET_KEY}
LIGHTRAG_WORKING_DIR=./LightRAG/.rag_storage
LIGHTRAG_INPUT_DIR=./LightRAG/.inputs
# LLM binding for LightRAG — point at Clawith LLM proxy when available,
# or configure directly (OpenAI-compatible).
LIGHTRAG_LLM_BINDING=openai
LIGHTRAG_LLM_MODEL=gpt-4o-mini
LIGHTRAG_LLM_BINDING_HOST=https://api.openai.com/v1
LIGHTRAG_LLM_BINDING_API_KEY=
LIGHTRAG_EMBEDDING_BINDING=openai
LIGHTRAG_EMBEDDING_MODEL=text-embedding-3-small
LIGHTRAG_EMBEDDING_DIM=1536

# ══ AIPPT (AI PPT frontend) ══
AIPPT_PORT=5173
# When integrated with Clawith SSO, AIPPT will read this token secret
VITE_JWT_SECRET=${JWT_SECRET_KEY}
# Point AIPPT's CUSTOM LLM provider at Clawith's LLM proxy (Phase 4)
VITE_CUSTOM_LLM_URL=http://localhost:8008/api/v1/llm-proxy
VITE_CUSTOM_API_KEY=
VITE_CUSTOM_MODEL=gpt-4o-mini

# ══ Database (shared by Clawith; LightRAG can use file-based NanoVectorDB) ══
DATABASE_URL=postgresql+asyncpg://clawith:clawith@localhost:5432/clawith?ssl=disable
