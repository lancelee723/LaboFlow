# ── Large local artifacts (not needed for Dockerfile.laboflow) ───────────────
.venv/
huggingface.co/
rag/res/
web/node_modules/
web/.vite/

# ── Python artifacts ──────────────────────────────────────────────────────────
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ── Git & IDE ─────────────────────────────────────────────────────────────────
.git/
.gitignore
.vscode/
.idea/

# ── Logs & runtime data ───────────────────────────────────────────────────────
logs/
*.log
docker/ragflow-logs/
.docling_tmp/

# Local compose/env secrets and runtime state
docker/.env
docker/.env.*

# Common local persistence folders that may contain user data
docker/oceanbase/data/
docker/oceanbase/conf/
docker/oceanbase/init.d/
docker/seekdb/

# Database dumps / local sqlite artifacts
**/*.db
**/*.sqlite
**/*.sqlite3
**/*.sqlite-wal
**/*.sqlite-shm

# User-generated content caches (defensive defaults)
# Note: **/chunk/ was removed — it would also exclude web/dist/chunk/ (Vite output).
# Instead, list the specific runtime data paths that should never go into the image.
**/uploads/
**/upload/
**/datasets/
**/dataset/
docker/**/chunks/
docker/**/chunk/
**/user_data/
**/userdata/

# ── Other Dockerfiles (only Dockerfile.laboflow is used in this build) ────────
Dockerfile
Dockerfile_tei
Dockerfile.deps
Dockerfile.scratch.oc9
