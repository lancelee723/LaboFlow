# ========== WHITELIST MODE ==========
# Ignore everything by default, then selectively allow specific items

# Ignore all files and folders
*

# ── Allow specific folders ──────────────────────
!aiPPT/
!Clawith/
!LightRAG/
!docs/
!docs/**

# ── Allow specific root-level files ─────────────
!.env.example
!README.md
!docker-compose.yml
!nginx.conf
!nginx/
!nginx/**
!dev.sh
!setup-all.sh
!stop.sh

# ── Always include .gitignore itself ────────────
!.gitignore

# ========== Common ignores (for allowed folders) ==========

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.claude/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node.js / Frontend
node_modules/
.pnpm-store/
dist/
build/
*.tsbuildinfo

# Docker
**/.dockerignore
docker-compose.override.yml

# Data & Storage
.data/
**/agent_data/
**/rag_storage/
**/inputs/
**/output/
**/data/
*.db
*.sqlite*
*.pid

# Logs
*.log
**/logs/
**/log/

# Backup
.backup/

# Miscellaneous
*.zip
*.tar.gz
*.tgz
*.lock
*.log
