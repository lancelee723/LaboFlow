# Image API Keys
# Get your free API keys from:
# - GIPHY: https://developers.giphy.com/
# - Pexels: https://www.pexels.com/api/
# - Unsplash: https://unsplash.com/developers
# - Pixabay: https://pixabay.com/api/docs/

VITE_GIPHY_API_KEY=your_giphy_api_key_here
VITE_PEXELS_API_KEY=your_pexels_api_key_here
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
VITE_PIXABAY_API_KEY=your_pixabay_api_key_here

# GitHub OAuth
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Set Authorization callback URL to: http://localhost:5173/jit-slide/login (or your production URL)
VITE_GITHUB_CLIENT_ID=your_github_client_id
VITE_GITHUB_REDIRECT_URI=http://localhost:5173/jit-slide/login

# Demo Account (for one-click experience on login page)
# If not set, the frontend will create a local guest session as fallback
VITE_DEMO_ACCOUNT=demo@aippt.cc
VITE_DEMO_PASSWORD=demo123456

# 科大讲飞语音识别（通过后端代理，前端不需要配置密钥）
# API 密钥配置在后端 server-slide/.env 文件中
