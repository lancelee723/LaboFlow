{
  "name": "slide",
  "projectType": "application",
  "sourceRoot": "apps/slide/src",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm dev",
        "cwd": "apps/slide"
      }
    },
    "serve:jitword": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm dev:jitword",
        "cwd": "apps/slide"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/jit-slide"],
      "options": {
        "command": "pnpm build",
        "cwd": "apps/slide"
      }
    },
    "build:jitword": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/jitword"],
      "options": {
        "command": "pnpm build:jitword",
        "cwd": "apps/slide"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm preview",
        "cwd": "apps/slide"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm lint",
        "cwd": "apps/slide"
      }
    }
  }
}