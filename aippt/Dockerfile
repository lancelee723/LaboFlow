FROM node:20-alpine AS builder

WORKDIR /app

# Use pnpm matching project lockfile.
RUN corepack enable

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .

# Build with /ppt/ as deploy base path to match gateway routing.
ARG APP_BASE_PATH=/ppt/
ENV NODE_ENV=production
RUN BASE_PATH=${APP_BASE_PATH} VITE_OUT_DIR=dist pnpm build

FROM nginx:1.27.1-alpine AS runtime

# Nginx serves static files generated by Vite.
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
  CMD wget -q -O /dev/null http://127.0.0.1/healthz || exit 1

CMD ["nginx", "-g", "daemon off;"]
